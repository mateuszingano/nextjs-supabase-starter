# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Local dev:   run `supabase start` and copy the URL + anon key it prints.
# Production:  Supabase dashboard → Project Settings → API.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser (no NEXT_PUBLIC_ prefix). Bypasses RLS.
# Optional for the app as shipped — add it when you write privileged server code.
# (The RLS tests read their own gitignored .env.test instead — see docs/testing.md.)
SUPABASE_SERVICE_ROLE_KEY=
